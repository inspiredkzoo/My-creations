# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git

# Anthropic API key — get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Google Service Account credentials
# (from the JSON key file you download from Google Cloud Console)
GOOGLE_SERVICE_ACCOUNT_EMAIL=mileage-tracker@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END RSA PRIVATE KEY-----\n"

# The ID of your Google Sheet (from the URL: /spreadsheets/d/THIS_PART/edit)
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id_here
